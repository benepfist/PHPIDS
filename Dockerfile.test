FROM ubuntu:24.04

# Avoid prompts
ENV DEBIAN_FRONTEND=noninteractive

# Update and install dependencies
RUN apt-get update && apt-get install -y \
    software-properties-common \
    curl \
    unzip \
    git \
    && add-apt-repository ppa:ondrej/php \
    && apt-get update \
    && apt-get install -y \
    php8.5-cli \
    php8.5-mbstring \
    php8.5-xml \
    php8.5-curl \
    php8.5-zip \
    php8.5-sqlite3 \
    php8.5-mysql \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Create a non-root user
RUN useradd -m -s /bin/bash phpids

# Set working directory
WORKDIR /app

# Change ownership of /app to phpids
RUN chown phpids:phpids /app

# Run as non-root user
USER phpids

# Copy the project files with correct ownership
COPY --chown=phpids:phpids . .

# Ensure tmp is clean
RUN rm -rf tmp && mkdir tmp

# Install dependencies
RUN composer update --ignore-platform-reqs --no-interaction --no-progress

# Run tests
CMD ["vendor/bin/phpunit"]
